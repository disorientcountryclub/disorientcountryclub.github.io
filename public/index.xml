    <item>
      <title>Promo Toolkit</title>
      <link>https://disorientcountry.club/promo/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://disorientcountry.club/promo/</guid>
      <description>&lt;h2 id=&#34;qr-code-generator&#34;&gt;QR Code Generator&lt;/h2&gt;&#xA;&lt;p&gt;Generate QR codes linking to Country Club. Right-click or long-press the generated QR code to save it.&lt;/p&gt;&#xA;&lt;div class=&#34;qr-generator&#34;&gt;&#xA;  &lt;div class=&#34;qr-controls&#34;&gt;&#xA;    &lt;label class=&#34;qr-label&#34; for=&#34;qr-path&#34;&gt;Page&lt;/label&gt;&#xA;    &lt;select id=&#34;qr-path&#34; class=&#34;qr-input&#34;&gt;&#xA;      &lt;option value=&#34;/&#34;&gt;Home&lt;/option&gt;&#xA;      &lt;option value=&#34;/get-involved/&#34;&gt;Get Involved&lt;/option&gt;&#xA;      &lt;option value=&#34;/lineup/&#34;&gt;Lineup&lt;/option&gt;&#xA;      &lt;option value=&#34;/art/&#34;&gt;Art&lt;/option&gt;&#xA;      &lt;option value=&#34;/camps/&#34;&gt;Camps&lt;/option&gt;&#xA;      &lt;option value=&#34;/guide/&#34;&gt;Guide&lt;/option&gt;&#xA;      &lt;option value=&#34;/announcements/&#34;&gt;Announcements&lt;/option&gt;&#xA;    &lt;/select&gt;&#xA;    &lt;label class=&#34;qr-label&#34; for=&#34;qr-size&#34;&gt;Size&lt;/label&gt;&#xA;    &lt;select id=&#34;qr-size&#34; class=&#34;qr-input&#34;&gt;&#xA;      &lt;option value=&#34;256&#34;&gt;256px&lt;/option&gt;&#xA;      &lt;option value=&#34;512&#34; selected&gt;512px&lt;/option&gt;&#xA;      &lt;option value=&#34;1024&#34;&gt;1024px&lt;/option&gt;&#xA;    &lt;/select&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;div class=&#34;qr-output&#34;&gt;&#xA;    &lt;canvas id=&#34;qr-canvas&#34;&gt;&lt;/canvas&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;a id=&#34;qr-download&#34; class=&#34;qr-download-btn&#34; download=&#34;country-club-qr.png&#34;&gt;Download PNG&lt;/a&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;script&gt;&#xA;&#xA;&#xA;(function() {&#xA;  &#xA;  &#xA;&#xA;  &#xA;  &#xA;  var GF256_EXP = new Array(256);&#xA;  var GF256_LOG = new Array(256);&#xA;  (function() {&#xA;    var v = 1;&#xA;    for (var i = 0; i &lt; 255; i++) {&#xA;      GF256_EXP[i] = v;&#xA;      GF256_LOG[v] = i;&#xA;      v &lt;&lt;= 1;&#xA;      if (v &gt;= 256) v ^= 0x11d;&#xA;    }&#xA;    GF256_EXP[255] = GF256_EXP[0];&#xA;  })();&#xA;&#xA;  function gfMul(a, b) {&#xA;    if (a === 0 || b === 0) return 0;&#xA;    return GF256_EXP[(GF256_LOG[a] + GF256_LOG[b]) % 255];&#xA;  }&#xA;&#xA;  function polyMul(a, b) {&#xA;    var result = new Array(a.length + b.length - 1).fill(0);&#xA;    for (var i = 0; i &lt; a.length; i++)&#xA;      for (var j = 0; j &lt; b.length; j++)&#xA;        result[i + j] ^= gfMul(a[i], b[j]);&#xA;    return result;&#xA;  }&#xA;&#xA;  function polyRemainder(dividend, divisor) {&#xA;    var result = dividend.slice();&#xA;    for (var i = 0; i &lt; dividend.length - divisor.length + 1; i++) {&#xA;      if (result[i] === 0) continue;&#xA;      for (var j = 1; j &lt; divisor.length; j++)&#xA;        result[i + j] ^= gfMul(divisor[j], result[i]);&#xA;    }&#xA;    return result.slice(dividend.length - divisor.length + 1);&#xA;  }&#xA;&#xA;  function getGeneratorPoly(degree) {&#xA;    var poly = [1];&#xA;    for (var i = 0; i &lt; degree; i++)&#xA;      poly = polyMul(poly, [1, GF256_EXP[i]]);&#xA;    return poly;&#xA;  }&#xA;&#xA;  &#xA;  var VERSION_CAPACITIES = [0,16,28,44,64,86,108,124,154,182,216,254,290,334,365,412,450,504,560,624,666];&#xA;  var EC_CODEWORDS = [0,10,16,26,18,24,16,18,22,22,26,30,22,22,24,24,28,28,26,26,28];&#xA;  var NUM_BLOCKS = [0,1,1,1,2,2,2,2,2,2,4,4,4,4,4,4,4,4,4,4,4]; &#xA;&#xA;  function getVersion(dataLen) {&#xA;    for (var v = 1; v &lt;= 20; v++) {&#xA;      if (dataLen &lt;= VERSION_CAPACITIES[v]) return v;&#xA;    }&#xA;    return 20;&#xA;  }&#xA;&#xA;  function encodeData(text) {&#xA;    &#xA;    var data = [];&#xA;    &#xA;    var bits = [];&#xA;&#xA;    function pushBits(value, count) {&#xA;      for (var i = count - 1; i &gt;= 0; i--)&#xA;        bits.push((value &gt;&gt; i) &amp; 1);&#xA;    }&#xA;&#xA;    var byteData = [];&#xA;    for (var i = 0; i &lt; text.length; i++) {&#xA;      var c = text.charCodeAt(i);&#xA;      if (c &lt; 128) byteData.push(c);&#xA;      else if (c &lt; 2048) {&#xA;        byteData.push(0xc0 | (c &gt;&gt; 6));&#xA;        byteData.push(0x80 | (c &amp; 0x3f));&#xA;      }&#xA;    }&#xA;&#xA;    var version = getVersion(byteData.length);&#xA;    var charCountBits = version &lt;= 9 ? 8 : 16;&#xA;&#xA;    pushBits(4, 4); &#xA;    pushBits(byteData.length, charCountBits);&#xA;&#xA;    for (var i = 0; i &lt; byteData.length; i++)&#xA;      pushBits(byteData[i], 8);&#xA;&#xA;    var totalDataCodewords = VERSION_CAPACITIES[version] + (version &lt;= 9 ? 0 : 0);&#xA;    &#xA;    var size = 17 + version * 4;&#xA;    var totalModules = size * size;&#xA;    &#xA;    var totalCodewords = Math.floor(totalModules / 8) - (version &lt;= 1 ? 36 : version &lt;= 6 ? 60 : 100); &#xA;    &#xA;    var ecCodewords = EC_CODEWORDS[version];&#xA;    var dataCodewords = VERSION_CAPACITIES[version];&#xA;&#xA;    &#xA;    var totalBitsNeeded = dataCodewords * 8;&#xA;    var terminatorLen = Math.min(4, totalBitsNeeded - bits.length);&#xA;    for (var i = 0; i &lt; terminatorLen; i++) bits.push(0);&#xA;&#xA;    &#xA;    while (bits.length % 8 !== 0) bits.push(0);&#xA;&#xA;    &#xA;    var padBytes = [0xEC, 0x11];&#xA;    var padIdx = 0;&#xA;    while (bits.length &lt; totalBitsNeeded) {&#xA;      pushBits(padBytes[padIdx % 2], 8);&#xA;      padIdx++;&#xA;    }&#xA;&#xA;    &#xA;    var codewords = [];&#xA;    for (var i = 0; i &lt; bits.length; i += 8) {&#xA;      var byte = 0;&#xA;      for (var j = 0; j &lt; 8; j++) byte = (byte &lt;&lt; 1) | (bits[i + j] || 0);&#xA;      codewords.push(byte);&#xA;    }&#xA;&#xA;    &#xA;    var genPoly = getGeneratorPoly(ecCodewords);&#xA;    var msgPoly = new Array(codewords.length + ecCodewords).fill(0);&#xA;    for (var i = 0; i &lt; codewords.length; i++) msgPoly[i] = codewords[i];&#xA;    var ecData = polyRemainder(msgPoly, genPoly);&#xA;&#xA;    return { version: version, data: codewords.concat(ecData), size: size, ecCodewords: ecCodewords };&#xA;  }&#xA;&#xA;  function createMatrix(version) {&#xA;    var size = 17 + version * 4;&#xA;    var matrix = [];&#xA;    var reserved = [];&#xA;    for (var i = 0; i &lt; size; i++) {&#xA;      matrix[i] = new Array(size).fill(0);&#xA;      reserved[i] = new Array(size).fill(false);&#xA;    }&#xA;&#xA;    function setModule(row, col, value) {&#xA;      if (row &gt;= 0 &amp;&amp; row &lt; size &amp;&amp; col &gt;= 0 &amp;&amp; col &lt; size) {&#xA;        matrix[row][col] = value ? 1 : 0;&#xA;        reserved[row][col] = true;&#xA;      }&#xA;    }&#xA;&#xA;    &#xA;    function drawFinder(row, col) {&#xA;      for (var r = -1; r &lt;= 7; r++) {&#xA;        for (var c = -1; c &lt;= 7; c++) {&#xA;          var val = false;&#xA;          if (r &gt;= 0 &amp;&amp; r &lt;= 6 &amp;&amp; c &gt;= 0 &amp;&amp; c &lt;= 6) {&#xA;            val = (r === 0 || r === 6 || c === 0 || c === 6 ||&#xA;                   (r &gt;= 2 &amp;&amp; r &lt;= 4 &amp;&amp; c &gt;= 2 &amp;&amp; c &lt;= 4));&#xA;          }&#xA;          setModule(row + r, col + c, val);&#xA;        }&#xA;      }&#xA;    }&#xA;&#xA;    drawFinder(0, 0);&#xA;    drawFinder(0, size - 7);&#xA;    drawFinder(size - 7, 0);&#xA;&#xA;    &#xA;    for (var i = 8; i &lt; size - 8; i++) {&#xA;      setModule(6, i, i % 2 === 0);&#xA;      setModule(i, 6, i % 2 === 0);&#xA;    }&#xA;&#xA;    &#xA;    if (version &gt;= 2) {&#xA;      var alignPos = getAlignmentPositions(version);&#xA;      for (var i = 0; i &lt; alignPos.length; i++) {&#xA;        for (var j = 0; j &lt; alignPos.length; j++) {&#xA;          var r = alignPos[i], c = alignPos[j];&#xA;          if (reserved[r][c]) continue;&#xA;          for (var dr = -2; dr &lt;= 2; dr++) {&#xA;            for (var dc = -2; dc &lt;= 2; dc++) {&#xA;              var val = (Math.abs(dr) === 2 || Math.abs(dc) === 2 || (dr === 0 &amp;&amp; dc === 0));&#xA;              setModule(r + dr, c + dc, val);&#xA;            }&#xA;          }&#xA;        }&#xA;      }&#xA;    }&#xA;&#xA;    &#xA;    for (var i = 0; i &lt; 8; i++) {&#xA;      if (!reserved[8][i]) { reserved[8][i] = true; }&#xA;      if (!reserved[i][8]) { reserved[i][8] = true; }&#xA;      if (!reserved[8][size - 1 - i]) { reserved[8][size - 1 - i] = true; }&#xA;      if (!reserved[size - 1 - i][8]) { reserved[size - 1 - i][8] = true; }&#xA;    }&#xA;    reserved[8][8] = true;&#xA;    &#xA;    setModule(size - 8, 8, true);&#xA;&#xA;    &#xA;    if (version &gt;= 7) {&#xA;      var versionBits = getVersionBits(version);&#xA;      for (var i = 0; i &lt; 18; i++) {&#xA;        var bit = (versionBits &gt;&gt; i) &amp; 1;&#xA;        var r = Math.floor(i / 3);&#xA;        var c = size - 11 + (i % 3);&#xA;        setModule(r, c, bit);&#xA;        setModule(c, r, bit);&#xA;      }&#xA;    }&#xA;&#xA;    return { matrix: matrix, reserved: reserved, size: size };&#xA;  }&#xA;&#xA;  function getAlignmentPositions(version) {&#xA;    if (version === 1) return [];&#xA;    var positions = [6];&#xA;    var last = 17 + version * 4 - 7;&#xA;    var count = Math.floor(version / 7) + 2;&#xA;    var step = Math.ceil((last - 6) / (count - 1));&#xA;    step = Math.ceil(step / 2) * 2; &#xA;    for (var pos = last; pos &gt; 6; pos -= step)&#xA;      positions.splice(1, 0, pos);&#xA;    return positions;&#xA;  }&#xA;&#xA;  function getVersionBits(version) {&#xA;    var rem = version;&#xA;    for (var i = 0; i &lt; 12; i++) rem = (rem &lt;&lt; 1) ^ ((rem &gt;&gt; 11) * 0x1F25);&#xA;    return (version &lt;&lt; 12) | rem;&#xA;  }&#xA;&#xA;  function placeData(matrixInfo, data) {&#xA;    var size = matrixInfo.size;&#xA;    var matrix = matrixInfo.matrix;&#xA;    var reserved = matrixInfo.reserved;&#xA;&#xA;    var bitIndex = 0;&#xA;    var totalBits = data.length * 8;&#xA;&#xA;    &#xA;    var upward = true;&#xA;    for (var col = size - 1; col &gt;= 1; col -= 2) {&#xA;      if (col === 6) col = 5; &#xA;      for (var i = 0; i &lt; size; i++) {&#xA;        var row = upward ? size - 1 - i : i;&#xA;        for (var dc = 0; dc &lt;= 1; dc++) {&#xA;          var c = col - dc;&#xA;          if (reserved[row][c]) continue;&#xA;          if (bitIndex &lt; totalBits) {&#xA;            var byteIdx = Math.floor(bitIndex / 8);&#xA;            var bitPos = 7 - (bitIndex % 8);&#xA;            matrix[row][c] = (data[byteIdx] &gt;&gt; bitPos) &amp; 1;&#xA;            bitIndex++;&#xA;          }&#xA;        }&#xA;      }&#xA;      upward = !upward;&#xA;    }&#xA;  }&#xA;&#xA;  function applyMask(matrix, reserved, size, maskNum) {&#xA;    var maskFn;&#xA;    switch(maskNum) {&#xA;      case 0: maskFn = function(r,c) { return (r+c)%2===0; }; break;&#xA;      case 1: maskFn = function(r,c) { return r%2===0; }; break;&#xA;      case 2: maskFn = function(r,c) { return c%3===0; }; break;&#xA;      case 3: maskFn = function(r,c) { return (r+c)%3===0; }; break;&#xA;      case 4: maskFn = function(r,c) { return (Math.floor(r/2)+Math.floor(c/3))%2===0; }; break;&#xA;      case 5: maskFn = function(r,c) { return (r*c)%2+(r*c)%3===0; }; break;&#xA;      case 6: maskFn = function(r,c) { return ((r*c)%2+(r*c)%3)%2===0; }; break;&#xA;      case 7: maskFn = function(r,c) { return ((r+c)%2+(r*c)%3)%2===0; }; break;&#xA;    }&#xA;    for (var r = 0; r &lt; size; r++)&#xA;      for (var c = 0; c &lt; size; c++)&#xA;        if (!reserved[r][c] &amp;&amp; maskFn(r,c))&#xA;          matrix[r][c] ^= 1;&#xA;  }&#xA;&#xA;  function applyFormatInfo(matrix, size, maskNum) {&#xA;    &#xA;    var ecLevel = 0; &#xA;    var formatData = (ecLevel &lt;&lt; 3) | maskNum;&#xA;    var rem = formatData;&#xA;    for (var i = 0; i &lt; 10; i++) rem = (rem &lt;&lt; 1) ^ ((rem &gt;&gt; 9) * 0x537);&#xA;    var formatBits = ((formatData &lt;&lt; 10) | rem) ^ 0x5412;&#xA;&#xA;    &#xA;    for (var i = 0; i &lt; 6; i++) matrix[8][i] = (formatBits &gt;&gt; (14-i)) &amp; 1;&#xA;    matrix[8][7] = (formatBits &gt;&gt; 8) &amp; 1;&#xA;    matrix[8][8] = (formatBits &gt;&gt; 7) &amp; 1;&#xA;    matrix[7][8] = (formatBits &gt;&gt; 6) &amp; 1;&#xA;    for (var i = 0; i &lt; 6; i++) matrix[5-i][8] = (formatBits &gt;&gt; (5-i)) &amp; 1;&#xA;&#xA;    for (var i = 0; i &lt; 7; i++) matrix[size-1-i][8] = (formatBits &gt;&gt; (14-i)) &amp; 1;&#xA;    for (var i = 0; i &lt; 8; i++) matrix[8][size-8+i] = (formatBits &gt;&gt; (7-i)) &amp; 1;&#xA;  }&#xA;&#xA;  function calculatePenalty(matrix, size) {&#xA;    var penalty = 0;&#xA;    &#xA;    for (var r = 0; r &lt; size; r++) {&#xA;      var count = 1;&#xA;      for (var c = 1; c &lt; size; c++) {&#xA;        if (matrix[r][c] === matrix[r][c-1]) { count++; }&#xA;        else { if (count &gt;= 5) penalty += count - 2; count = 1; }&#xA;      }&#xA;      if (count &gt;= 5) penalty += count - 2;&#xA;    }&#xA;    for (var c = 0; c &lt; size; c++) {&#xA;      var count = 1;&#xA;      for (var r = 1; r &lt; size; r++) {&#xA;        if (matrix[r][c] === matrix[r-1][c]) { count++; }&#xA;        else { if (count &gt;= 5) penalty += count - 2; count = 1; }&#xA;      }&#xA;      if (count &gt;= 5) penalty += count - 2;&#xA;    }&#xA;    &#xA;    for (var r = 0; r &lt; size-1; r++)&#xA;      for (var c = 0; c &lt; size-1; c++)&#xA;        if (matrix[r][c]===matrix[r][c+1] &amp;&amp; matrix[r][c]===matrix[r+1][c] &amp;&amp; matrix[r][c]===matrix[r+1][c+1])&#xA;          penalty += 3;&#xA;    return penalty;&#xA;  }&#xA;&#xA;  function generateQR(text) {&#xA;    var encoded = encodeData(text);&#xA;    var best = null, bestPenalty = Infinity;&#xA;&#xA;    for (var mask = 0; mask &lt; 8; mask++) {&#xA;      var mi = createMatrix(encoded.version);&#xA;      placeData(mi, encoded.data);&#xA;      applyMask(mi.matrix, mi.reserved, mi.size, mask);&#xA;      applyFormatInfo(mi.matrix, mi.size, mask);&#xA;      var p = calculatePenalty(mi.matrix, mi.size);&#xA;      if (p &lt; bestPenalty) { bestPenalty = p; best = mi.matrix; }&#xA;    }&#xA;&#xA;    return { matrix: best, size: encoded.size };&#xA;  }&#xA;&#xA;  &#xA;  var logoImg = new Image();&#xA;  logoImg.crossOrigin = &#39;anonymous&#39;;&#xA;  logoImg.src = &#39;\/images\/20260121.CCXiVVexillum.png&#39;;&#xA;  var logoLoaded = false;&#xA;  logoImg.onload = function() { logoLoaded = true; update(); };&#xA;&#xA;  &#xA;  var fontReady = false;&#xA;  var disorientFont = new FontFace(&#39;Disorient&#39;, &#34;url(&#39;\/fonts\/Disorient 2017.ttf&#39;)&#34;);&#xA;  disorientFont.load().then(function(loaded) {&#xA;    document.fonts.add(loaded);&#xA;    fontReady = true;&#xA;    update();&#xA;  }).catch(function() { fontReady = false; });&#xA;&#xA;  function renderQR(canvas, qr, targetSize) {&#xA;    var quiet = 4; &#xA;    var totalModules = qr.size + quiet * 2;&#xA;&#xA;    &#xA;    var qrCanvasSize = targetSize;&#xA;    var pixelSize = targetSize / totalModules;&#xA;&#xA;    &#xA;    var textHeight = Math.round(qrCanvasSize * 0.12);&#xA;    var textPadding = Math.round(qrCanvasSize * 0.03);&#xA;    var canvasWidth = qrCanvasSize;&#xA;    var canvasHeight = qrCanvasSize + textHeight + textPadding;&#xA;&#xA;    canvas.width = canvasWidth;&#xA;    canvas.height = canvasHeight;&#xA;&#xA;    var ctx = canvas.getContext(&#39;2d&#39;);&#xA;&#xA;    &#xA;    ctx.fillStyle = &#39;#ffffff&#39;;&#xA;    ctx.fillRect(0, 0, canvasWidth, canvasHeight);&#xA;&#xA;    &#xA;    var gradient = ctx.createLinearGradient(0, 0, qrCanvasSize, qrCanvasSize);&#xA;    gradient.addColorStop(0, &#39;#ff8800&#39;);&#xA;    gradient.addColorStop(1, &#39;#ff0088&#39;);&#xA;    ctx.fillStyle = gradient;&#xA;&#xA;    &#xA;    for (var r = 0; r &lt; qr.size; r++) {&#xA;      for (var c = 0; c &lt; qr.size; c++) {&#xA;        if (qr.matrix[r][c]) {&#xA;          var x = (c + quiet) * pixelSize;&#xA;          var y = (r + quiet) * pixelSize;&#xA;          &#xA;          ctx.fillRect(Math.floor(x), Math.floor(y),&#xA;            Math.ceil(pixelSize), Math.ceil(pixelSize));&#xA;        }&#xA;      }&#xA;    }&#xA;&#xA;    &#xA;    if (logoLoaded) {&#xA;      var logoSize = Math.round(qrCanvasSize * 0.15);&#xA;      var logoPadding = Math.round(logoSize * 0.05);&#xA;      var bgSize = logoSize + logoPadding * 2;&#xA;&#xA;      &#xA;      ctx.fillStyle = &#39;#ffffff&#39;;&#xA;      ctx.beginPath();&#xA;      ctx.arc(qrCanvasSize / 2, qrCanvasSize / 2, bgSize / 2, 0, Math.PI * 2);&#xA;      ctx.fill();&#xA;&#xA;      &#xA;      var lx = Math.round((qrCanvasSize - logoSize) / 2);&#xA;      var ly = Math.round((qrCanvasSize - logoSize) / 2);&#xA;      ctx.drawImage(logoImg, lx, ly, logoSize, logoSize);&#xA;    }&#xA;&#xA;    &#xA;    var fontSize = Math.round(textHeight * 0.35);&#xA;    var fontName = fontReady ? &#39;Disorient&#39; : &#39;Orbitron, monospace&#39;;&#xA;    ctx.font = fontSize + &#39;px &#39; + fontName;&#xA;    ctx.textAlign = &#39;center&#39;;&#xA;    ctx.textBaseline = &#39;middle&#39;;&#xA;&#xA;    &#xA;    var textGradient = ctx.createLinearGradient(&#xA;      canvasWidth * 0.2, 0, canvasWidth * 0.8, 0&#xA;    );&#xA;    textGradient.addColorStop(0, &#39;#ff8800&#39;);&#xA;    textGradient.addColorStop(1, &#39;#ff0088&#39;);&#xA;    ctx.fillStyle = textGradient;&#xA;&#xA;    var textY = qrCanvasSize + textPadding + textHeight / 2;&#xA;    ctx.fillText(&#39;COUNTRY CLUB CCXIV&#39;, canvasWidth / 2, textPadding * 1.5);&#xA;    ctx.fillText(&#39;SECRET&#39;, canvasWidth / 2, textY - textPadding * 4.25);&#xA;    ctx.fillText(&#39;UPSTATE LOCATION&#39;, canvasWidth / 2, textY - textPadding * 2.5);&#xA;    ctx.fillText(&#39;MAY 21-25&#39;, canvasWidth / 2, textY);&#xA;  }&#xA;&#xA;  &#xA;  function update() {&#xA;    var path = document.getElementById(&#39;qr-path&#39;).value;&#xA;    var size = parseInt(document.getElementById(&#39;qr-size&#39;).value);&#xA;    var url = &#39;https:\/\/disorientcountry.club\/&#39;.replace(/\/$/, &#39;&#39;) + path;&#xA;&#xA;    var qr = generateQR(url);&#xA;    var canvas = document.getElementById(&#39;qr-canvas&#39;);&#xA;    renderQR(canvas, qr, size);&#xA;&#xA;    var link = document.getElementById(&#39;qr-download&#39;);&#xA;    link.href = canvas.toDataURL(&#39;image/png&#39;);&#xA;    var pageName = document.getElementById(&#39;qr-path&#39;).selectedOptions[0].text.toLowerCase().replace(/\s+/g, &#39;-&#39;);&#xA;    link.download = &#39;country-club-qr-&#39; + pageName + &#39;-&#39; + size + &#39;x&#39; + size + &#39;.png&#39;;&#xA;  }&#xA;&#xA;  document.getElementById(&#39;qr-path&#39;).addEventListener(&#39;change&#39;, update);&#xA;  document.getElementById(&#39;qr-size&#39;).addEventListener(&#39;change&#39;, update);&#xA;  &#xA;  update();&#xA;})();&#xA;&lt;/script&gt;</description>
